{
  "name": "telemedicine-service",
  "version": "1.0.0",
  "description": "Telemedicine video session service using Daily.co",
  "main": "dist/scripts/start.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/scripts/start.js",
    "dev": "ts-node scripts/start.ts",
    "test": "jest --forceExit"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.6",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/__tests__/**/*.test.ts"],
    "moduleFileExtensions": ["ts", "js", "json"]
  }
}
